{
  "@context": {
    "@version": 1.1,
    "schema": "https://schema.org/",
    "ual": "https://api-evangelist.com/vocab/university-of-alberta#",
    "dvn": "https://borealisdata.ca/schema/dataverse#",

    "University": "schema:CollegeOrUniversity",
    "name": "schema:name",
    "url": "schema:url",

    "Dataset": "schema:Dataset",
    "Dataverse": "dvn:Dataverse",
    "DataFile": "schema:DataDownload",

    "description": "schema:description",
    "publisher": { "@id": "schema:publisher" },
    "published_at": { "@id": "schema:datePublished", "@type": "schema:DateTime" },
    "createdAt": { "@id": "schema:dateCreated", "@type": "schema:DateTime" },
    "updatedAt": { "@id": "schema:dateModified", "@type": "schema:DateTime" },
    "global_id": { "@id": "schema:identifier" },
    "citation": "schema:citation",
    "keywords": { "@id": "schema:keywords", "@container": "@set" },
    "subjects": { "@id": "schema:about", "@container": "@set" },
    "authors": { "@id": "schema:author", "@container": "@set" },
    "producers": { "@id": "schema:producer", "@container": "@set" },
    "contacts": { "@id": "schema:contactPoint", "@container": "@set" },
    "geographicCoverage": { "@id": "schema:spatialCoverage", "@container": "@set" },
    "name_of_dataverse": "dvn:nameOfDataverse",
    "identifier_of_dataverse": "dvn:identifierOfDataverse",
    "versionState": "dvn:versionState",
    "fileCount": { "@id": "dvn:fileCount", "@type": "schema:Integer" },
    "affiliation": "schema:affiliation",
    "country": "schema:addressCountry",
    "state": "schema:addressRegion",
    "city": "schema:addressLocality"
  },
  "@type": "University",
  "name": "University of Alberta",
  "url": "https://www.ualberta.ca/"
}
